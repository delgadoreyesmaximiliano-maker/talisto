# ─────────────────────────────────────────────
# Supabase (REQUIRED)
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────
# AI — Groq (REQUIRED)
# ─────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key

# ─────────────────────────────────────────────
# Telegram Bot (REQUIRED for Telegram integration)
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ─────────────────────────────────────────────
# WhatsApp (OPTIONAL)
# ─────────────────────────────────────────────
WHATSAPP_WEBHOOK_SECRET=your-whatsapp-webhook-secret
DEFAULT_COUNTRY_CODE=56

# ─────────────────────────────────────────────
# Rate limiting — Upstash Redis (OPTIONAL)
# If not set, rate limiting is disabled silently.
# ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─────────────────────────────────────────────
# Cron jobs (REQUIRED in production)
# Without this, /api/cron/* endpoints are publicly accessible.
# ─────────────────────────────────────────────
CRON_SECRET=your-random-secret-min-32-chars

# ─────────────────────────────────────────────
# Email — Resend (OPTIONAL)
# ─────────────────────────────────────────────
RESEND_API_KEY=your-resend-api-key
